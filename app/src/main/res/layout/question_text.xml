<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_question_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:id="@+id/card_question_card_back"
            style="@style/QuestionCardStyle"
            android:layout_width="match_parent"
            android:layout_height="205dp"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/question_text"
            style="@style/Body.Medium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:elevation="1dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="4"
            android:text=""
            android:textAlignment="center"
            android:textColor="@color/shade_primary"
            app:layout_constraintBottom_toBottomOf="@id/card_question_card_back"
            app:layout_constraintEnd_toEndOf="@id/card_question_card_back"
            app:layout_constraintStart_toStartOf="@id/card_question_card_back"
            app:layout_constraintTop_toTopOf="@id/card_question_card_back"
            tools:text="Which of the following best explains how a country's physical geography can influence its level of economic development?" />

        <com.barcelona.qurio.presentation.custom_view.TitleCard
            android:id="@+id/question_number_text"
            android:layout_width="145dp"
            android:layout_height="40dp"
            android:layout_marginTop="-16dp"
            app:cardTitle="Q 1/12"
            app:layout_constraintEnd_toEndOf="@id/card_question_card_back"
            app:layout_constraintStart_toStartOf="@id/card_question_card_back"
            app:layout_constraintTop_toTopOf="@id/card_question_card_back" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>
