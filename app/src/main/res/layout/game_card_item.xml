<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="gameCardData"
            type="com.barcelona.qurio.presentation.model.gamecard.GameCardModel" />
    </data>



        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingHorizontal="8dp"
            android:paddingBottom="22dp">
            <com.barcelona.qurio.presentation.custom_view.GameCard
                android:id="@+id/game_image"
                android:layout_width="wrap_content"
                android:layout_height="366dp"
                app:bindCardData="@{gameCardData}"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/text_title"
                style="@style/Title.Large"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@{gameCardData.title}"
                android:textAlignment="center"
                android:textColor="@color/on_primary"
                app:layout_constraintBottom_toTopOf="@id/play_button"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <include
                android:id="@+id/play_button"
                layout="@layout/play_button"
                android:layout_width="166dp"
                android:layout_height="44dp"
                android:layout_marginTop="-22dp"
                app:layout_constraintEnd_toEndOf="@id/game_image"
                app:layout_constraintStart_toStartOf="@id/game_image"
                app:layout_constraintTop_toBottomOf="@id/game_image" />
        </androidx.constraintlayout.widget.ConstraintLayout>
</layout>