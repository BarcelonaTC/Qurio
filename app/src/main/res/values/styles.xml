<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ButtonCorner">
        <item name="cornerFamilyTopLeft">cut</item>
        <item name="cornerFamilyBottomRight">cut</item>
        <item name="cornerSizeTopLeft">7dp</item>
        <item name="cornerSizeBottomRight">7dp</item>
        <item name="cornerSizeTopRight">2dp</item>
        <item name="cornerSizeBottomLeft">2dp</item>
    </style>

    <style name="ButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/difficulty_button_color</item>
        <item name="textAllCaps">false</item>
        <item name="shapeAppearanceOverlay">@style/ButtonCorner</item>
        <item name="android:textAppearance">@style/Label.Medium</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="strokeColor">@color/shade_quad</item>
    </style>

</resources>