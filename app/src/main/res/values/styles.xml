<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ChipCorner">
        <item name="cornerFamilyTopLeft">cut</item>
        <item name="cornerFamilyBottomRight">cut</item>
        <item name="cornerSizeTopLeft">7dp</item>
        <item name="cornerSizeBottomRight">7dp</item>
        <item name="cornerSizeTopRight">2dp</item>
        <item name="cornerSizeBottomLeft">2dp</item>
    </style>

    <style name="ChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/difficulty_button_color</item>
        <item name="textAllCaps">false</item>
        <item name="shapeAppearanceOverlay">@style/ChipCorner</item>
        <item name="android:textAppearance">@style/Label.Medium</item>
        <item name="chipStrokeWidth">0.5dp</item>
        <item name="chipStrokeColor">@color/shade_quad</item>
        <item name="android:textColor">@color/difficulty_button_text_color</item>
        <item name="chipMinHeight">37dp</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="TextButton">
        <item name="android:textAppearance">@style/Label.Medium</item>
        <item name="android:textColor">@color/text_button_color</item>
    </style>

    <style name="PrimaryButtonText">
        <item name="android:textAppearance">@style/Label.Medium</item>
        <item name="android:textColor">@color/primary_button_text_color</item>
    </style>

    <style name="QuestionCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:foreground">@drawable/question_card</item>
        <item name="cardElevation">0dp</item>
    </style>
    <style name="LastGameStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:foreground">@drawable/last_game_card_shape</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="AnswerStyle">
        <item name="cornerRadius">12dp</item>
        <item name="borderWidth">1dp</item>
        <item name="cardBorderColor">@color/shade_quad</item>
    </style>

    <style name="ShapeAppearance.App.CharacterCard" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">12dp</item>
        <item name="cornerSizeBottomRight">12dp</item>
        <item name="cornerSizeBottomLeft">12dp</item>
        <item name="cornerSizeTopLeft">2dp</item>
    </style>

    <style name="CutCornerCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:foreground">@drawable/buy_life_shape</item>
    </style>
</resources>