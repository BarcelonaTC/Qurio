<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Qurio" parent="carbon_Theme.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Qurio" parent="Base.Theme.Qurio" />
    <style name="Theme.Qurio.Starter" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_inset</item>
        <item name="windowSplashScreenBackground">@color/surface</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="postSplashScreenTheme">@style/Theme.Qurio</item>
    </style>

    <style name="QuestionCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:foreground">@drawable/question_card</item>
        <item name="cardElevation">0dp</item>
    </style>
</resources>